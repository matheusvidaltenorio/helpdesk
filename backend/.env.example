# Cópia este arquivo para .env e preencha os valores
# cp .env.example .env

# Porta do servidor
PORT=3000

# Banco de dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=helpdesk
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# JWT (gere uma chave aleatória forte em produção)
JWT_SECRET=minha_chave_secreta_muito_segura

# Produção: use DATABASE_URL (Render, Railway) ou variáveis separadas
# CORS_ORIGIN=https://helpdesk-web-lxze.onrender.com (ou separados por vírgula)
